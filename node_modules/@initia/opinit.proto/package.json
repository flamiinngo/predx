{
  "name": "@initia/opinit.proto",
  "version": "1.0.3",
  "description": "JS and TS types relating to Protocol Buffers used by OPinit project",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/initia-labs/OPinit.proto"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "amino/",
    "cosmos/",
    "cosmos_proto/",
    "gogoproto/",
    "google/",
    "opinit/",
    "tendermint/",
    "*.md"
  ],
  "scripts": {
    "format": "prettier --write --loglevel warn \"./src/**/*.ts\"",
    "build": "rm -rf ./build && tsc --module commonjs && ./scripts/prepare.sh",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/google-protobuf": "^3.15.12",
    "@types/node": "^20",
    "prettier": "^3",
    "ts-proto": "^2.7.5",
    "typescript": "^5"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.5.2",
    "@improbable-eng/grpc-web": "^0.15.0",
    "browser-headers": "^0.4.1"
  }
}
